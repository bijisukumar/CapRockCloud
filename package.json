{
  "name": "caprock-cloud",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev ./dist --d1=CAPROCK_DB",
    "db:migrate:local": "wrangler d1 migrations apply caprock-db --local",
